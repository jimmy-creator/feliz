PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecom_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=https://felizoman.com

# Currency — OMR (Omani Rial). Used in emails, PDF invoices, schema.org
# product pricing, and payment gateway calls.
CURRENCY_SYMBOL=OMR
CURRENCY_CODE=OMR
CURRENCY_DECIMALS=3

# Store details shown on PDF invoices (all optional)
STORE_NAME=Fineline Solutions
STORE_ADDRESS=
STORE_PHONE=
STORE_TRN=          # UAE Tax Registration Number (printed on invoices)

# Server URL — used to build payment gateway server-to-server callback URLs
SERVER_URL=http://localhost:5000

# Tamara (Buy Now Pay Later — UAE/GCC). Setting TAMARA_API_TOKEN enables it
# as a checkout option. Get the token from the Tamara merchant portal.
TAMARA_API_TOKEN=
TAMARA_API_URL=https://api-sandbox.tamara.co   # production: https://api.tamara.co
# TAMARA_PAYMENT_TYPE=PAY_BY_INSTALMENTS       # or PAY_NOW / PAY_NEXT_MONTH
# TAMARA_INSTALMENTS=3

# Enable /ar hreflang alternates + Arabic crawler meta + /ar sitemap URLs
FEATURE_I18N=true
